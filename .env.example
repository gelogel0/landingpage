# =====================================================================
# chsh studio landing — environment variables
# =====================================================================
#
# Copy this file to `.env.local` for local dev (`npm run dev`) or paste
# the values into Vercel → Project Settings → Environment Variables for
# production. Variables prefixed with VITE_ are public (compiled into the
# browser bundle); variables WITHOUT VITE_ are server-only (read by
# /api/* serverless functions).
#
# Missing values are gracefully ignored — the corresponding script /
# integration is simply not loaded.

# ---------- Server-only (Vercel functions) ----------

# Telegram bot token. Get from @BotFather (/mybots → API Token).
# After this token has been exposed (e.g. in a leaked deploy), revoke it
# from BotFather and put the NEW token here.
TG_BOT_TOKEN=

# Telegram chat id where leads are delivered. Negative numbers for
# channels/groups, positive for direct chats.
TG_CHAT_ID=

# ---------- Public (browser bundle) ----------

# Yandex Metrika counter id. metrika.yandex.ru → Создать счётчик.
# Example: 100123456
VITE_YM_ID=

# Microsoft Clarity project id. clarity.microsoft.com → Add new project.
# Example: abcd1234ef
VITE_CLARITY_ID=

# Meta (Facebook/Instagram) Pixel id. business.facebook.com → Events Manager.
# Example: 1234567890123456
VITE_META_PIXEL_ID=

# TikTok Pixel id. ads.tiktok.com → Tools → Events.
VITE_TIKTOK_PIXEL_ID=
