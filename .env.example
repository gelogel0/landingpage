# =====================================================================
# chsh studio landing — environment variables
# =====================================================================
#
# Copy this file to `.env.local` for local dev (`npm run dev`) or paste
# the values into Vercel → Project Settings → Environment Variables for
# production. Variables prefixed with VITE_ are public (compiled into the
# browser bundle); variables WITHOUT VITE_ are server-only (read by
# /api/* serverless functions).
#
# Missing values are gracefully ignored — the corresponding script /
# integration is simply not loaded.

# ---------- Server-only (Vercel functions) ----------

# Telegram bot token. Get from @BotFather (/mybots → API Token).
# After this token has been exposed (e.g. in a leaked deploy), revoke it
# from BotFather and put the NEW token here.
TG_BOT_TOKEN=

# Telegram chat id where leads are delivered. Negative numbers for
# channels/groups, positive for direct chats.
TG_CHAT_ID=

# Optional: explicit CORS origin for /api/lead. Leave empty for same-origin only.
# Example: https://chsh.online
ALLOW_ORIGIN=

# Optional: public Calendly link surfaced by the discovery bot (/api/tg-webhook)
# at the end of the qualification flow. If unset, the bot falls back to a
# WhatsApp deep-link.
# Example: https://calendly.com/chsh-studio/audit-30min
CALENDLY_URL=

# Optional: WhatsApp number used by the discovery bot fallback CTA (digits only).
# Defaults to 77757767666 if unset.
WA_NUMBER=

# Optional but recommended: random string. If set, /api/tg-webhook will reject
# requests whose X-Telegram-Bot-Api-Secret-Token header doesn't match.
# Generate one with: openssl rand -hex 24
TG_WEBHOOK_SECRET=

# ---------- AI lead bot (api/tg-webhook.ts) ----------
# Provider-agnostic: any OpenAI-compatible Chat Completions endpoint works
# (OpenAI now, an OmniRoute / other gateway later — just change these 3).
# Without LLM_API_KEY (or without Supabase below) the bot falls back to a
# static greeting + booking CTA — it never crashes.

# API key for the LLM gateway. For OpenAI: platform.openai.com → API Keys.
LLM_API_KEY=

# Optional: base URL. Default https://api.openai.com/v1.
# For a self-hosted OmniRoute gateway: https://<your-omniroute-host>/v1
LLM_BASE_URL=

# Optional: model. Default gpt-4o-mini (fast + cheap, great for qualification).
# Via OmniRoute you can route to free Claude/GPT/Gemini, e.g. provider/model.
LLM_MODEL=

# Supabase project — stores leads + per-chat conversation state.
# Run supabase/schema.sql once. Settings → API → use the SERVICE ROLE key
# (server-only — never expose to the browser).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Public (browser bundle) ----------

# Yandex Metrika counter id. metrika.yandex.ru → Создать счётчик.
# Example: 100123456
VITE_YM_ID=

# Microsoft Clarity project id. clarity.microsoft.com → Add new project.
# Example: abcd1234ef
VITE_CLARITY_ID=

# Meta (Facebook/Instagram) Pixel id. business.facebook.com → Events Manager.
# Example: 1234567890123456
VITE_META_PIXEL_ID=

# TikTok Pixel id. ads.tiktok.com → Tools → Events.
VITE_TIKTOK_PIXEL_ID=

# Telegram bot username (without @) for the form→bot deep-link button.
# The qualification BOT, not your personal account. Example: chsh_studio_bot
VITE_TG_BOT_USERNAME=
